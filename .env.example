# Sentinel-AWS — local secrets skeleton.
#
# Copy to `.env` (gitignored) or set directly in your shell. Nothing in this
# repo auto-loads .env; set the variables in the environment that runs pytest:
#
#   PowerShell:  $env:ANTHROPIC_API_KEY = "sk-ant-..."
#   bash/zsh:    export ANTHROPIC_API_KEY="sk-ant-..."
#   conda:       conda env config vars set -n aws ANTHROPIC_API_KEY=sk-ant-...
#
# In AWS these values live in Secrets Manager (pushed out-of-band, never in
# Terraform state) — see implementation_plan.md.

# Required for: live smoke test (pytest -m live), eval LLM arms (Phase 3+).
ANTHROPIC_API_KEY=

# Optional until Phase 5 (alerting): incoming-webhook URL for high-severity alerts.
SLACK_WEBHOOK_URL=
