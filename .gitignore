# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
aws/

# Environment / secrets — never commit
.env
.env.*
!.env.example
*.pem

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
# Per-env config is non-secret by design (secrets live in Secrets Manager,
# pushed out-of-band) — keep the env files versioned.
!terraform/envs/*.tfvars
.terraform.lock.hcl
terraform/plan.out

# Lambda build artifacts
build/
dist/
*.zip

# Eval corpora (regenerated from seeded generator; results.md IS committed)
eval/corpus/
eval/output/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude Code local settings
.claude/settings.local.json
